@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject CustomAuthStateProvider AuthProvider

<MudLayout>
    <AuthorizeView>
        <Authorized>
            <MudAppBar Elevation="0" Style="background:#0F172A; border-bottom:1px solid rgba(148,163,184,.1);">
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="@(() => _drawerOpen = !_drawerOpen)" />
                <MudText Typo="Typo.subtitle1" Class="app-brand ml-1">Sponsorship Portal</MudText>
                <MudSpacer />
                <MudText Typo="Typo.caption" Style="color:#94A3B8" Class="mr-2">@context.User.FindFirst("name")?.Value</MudText>
                <MudAvatar Style="background:#2563EB; color:white; width:32px; height:32px; font-size:0.8rem; margin-right:4px;">
                    @(context.User.FindFirst("name")?.Value?.Substring(0,1).ToUpper() ?? "U")
                </MudAvatar>
                <MudTooltip Text="Logout">
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="LogoutAsync" Size="Size.Small" />
                </MudTooltip>
            </MudAppBar>
            <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Style="background:#0F172A; border-right:1px solid rgba(148,163,184,.08);">
                <div class="drawer-logo d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.VolunteerActivism" Style="color:#2563EB" />
                    <MudText Typo="Typo.subtitle2" Style="color:#F1F5F9; font-weight:700;">SponsorHub</MudText>
                </div>
                <NavMenu />
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    async Task LogoutAsync()
    {
        await AuthProvider.NotifyLogoutAsync();
        Nav.NavigateTo("/login", true);
    }
}
