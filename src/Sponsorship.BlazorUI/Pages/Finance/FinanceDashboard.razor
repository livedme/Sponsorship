@page "/finance"
@attribute [Authorize(Roles = "FinanceAdmin")]
@inject ApiService Api

<PageTitle>Finance – Review Queue</PageTitle>

<div class="page-header d-flex align-center justify-space-between">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:700; color:white; margin:0;">Finance Review Queue</MudText>
        <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.75); margin:0;">Process and finalise sponsorship funding</MudText>
    </div>
    <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Style="font-size:2rem; color:rgba(255,255,255,0.4);" />
</div>

@if (_requests == null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    var pending = _requests.Where(r => r.Status == "PendingFinanceReview").ToList();
    var others = _requests.Where(r => r.Status == "Approved" || r.Status == "Rejected").ToList();

    <MudPaper Elevation="1" Class="pa-4 mb-4">
        <div class="d-flex align-center gap-2 mb-3">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Awaiting Finance Review</MudText>
            @if (pending.Count > 0)
            {
                <MudBadge Content="@pending.Count" Color="Color.Warning" Overlap="false">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Color="Color.Warning" />
                </MudBadge>
            }
        </div>
        <RequestsTable Requests="pending" />
    </MudPaper>

    <MudPaper Elevation="1" Class="pa-4">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;" Class="mb-3">All Other Requests</MudText>
        <RequestsTable Requests="others" />
    </MudPaper>
}

@code {
    List<SponsorshipRequestDto>? _requests;
    protected override async Task OnInitializedAsync()
        => _requests = await Api.GetMyRequestsAsync();
}
