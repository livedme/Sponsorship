<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudSnackbarProvider />

@code {
    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#2563EB",
            PrimaryDarken = "#1D4ED8",
            PrimaryLighten = "#DBEAFE",
            Secondary = "#7C3AED",
            Tertiary = "#0EA5E9",
            AppbarBackground = "#2563EB",
            AppbarText = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#0F172A",
            DrawerIcon = "#2563EB",
            Background = "#F1F5F9",
            BackgroundGray = "#E2E8F0",
            Surface = "#FFFFFF",
            TextPrimary = "#0F172A",
            TextSecondary = "#475569",
            ActionDefault = "#64748B",
            Divider = "#E2E8F0",
            Success = "#10B981",
            Warning = "#F59E0B",
            Error = "#EF4444",
            Info = "#3B82F6",
            OverlayLight = "rgba(15,23,42,0.4)",
        },
        LayoutProperties = new LayoutProperties
        {
            DrawerWidthLeft = "260px",
            AppbarHeight = "64px",
        },
        Shadows = new Shadow(),
        ZIndex = new ZIndex()
    };
}

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudText Typo="Typo.h5" Class="ma-4">Page not found.</MudText>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
